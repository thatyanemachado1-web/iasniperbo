# Copie para scripts/official_publisher.local.env na VPS (Linux) ou no PC (Windows).
# Nunca commite o arquivo .local.env (contém segredos).

SNIPER_ADMIN_EMAIL=seu-email-admin@sniperbo.com
SNIPER_ADMIN_PASSWORD=sua-senha-admin

# Token Bearer admin. Obtenha após login em https://sniperbo.com/app/admin:
# DevTools > Application > Local Storage > sniper_admin_session > campo "token"
SNIPER_ADMIN_TOKEN=

# Token para ler dashboard local (signals API). Pode ser igual ao admin.
SNIPER_LOCAL_DASHBOARD_TOKEN=

# Header x-sniper-publisher-token no POST /dashboard/publish
# Deve coincidir com SNIPER_PUBLISHER_TOKEN no Cloudflare Workers.
SNIPER_PUBLISHER_TOKEN=

SNIPER_REMOTE_DASHBOARD_TOKEN=

PUBLISHER_INTERVAL=0.25
FRONTEND_PORT=5175
SIGNALS_API_PORT=8787
SIGNALS_API_HOST=127.0.0.1
SNIPER_LOCAL_DASHBOARD_URL=http://127.0.0.1:8787/dashboard

# --- VPS Linux (systemd) ---
# Repo em /opt/iasniperbo, usuário sniper:
#   sudo cp deploy/systemd/*.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now sniper-signals-api sniper-publisher
#   # ou só o watchdog (reinicia os dois):
#   sudo systemctl enable --now sniper-watchdog
#
# Diagnóstico:
#   bash scripts/diagnose_official_publisher.sh --restart --smoke
#
# O publisher lê http://127.0.0.1:8787/dashboard — a signals-api precisa
# receber rodadas (scraper/coletor). Sem isso, nada chega em sniperbo.com.
