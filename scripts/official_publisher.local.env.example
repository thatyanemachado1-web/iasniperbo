# Copie para scripts/official_publisher.local.env e preencha os valores reais.
# Nunca commite o arquivo .local.env (contém segredos).

SNIPER_ADMIN_EMAIL=seu-email-admin@sniperbo.com
SNIPER_ADMIN_PASSWORD=sua-senha-admin

# Token de sessao admin (Bearer). Obtenha apos login em sniperbo.com/app/admin:
# DevTools > Application > Local Storage > sniper_admin_session > campo "token"
SNIPER_ADMIN_TOKEN=

# Token para ler dashboard local (signals API :8787). Pode ser igual ao admin.
SNIPER_LOCAL_DASHBOARD_TOKEN=

# Token enviado no header x-sniper-publisher-token para POST /dashboard/publish
# Deve coincidir com SNIPER_PUBLISHER_TOKEN (ou SNIPER_DASHBOARD_TOKEN) no Cloudflare Workers.
SNIPER_PUBLISHER_TOKEN=

# Alias opcional do token remoto (fallback se SNIPER_PUBLISHER_TOKEN vazio)
SNIPER_REMOTE_DASHBOARD_TOKEN=

PUBLISHER_INTERVAL=0.7
FRONTEND_PORT=5175
SIGNALS_API_PORT=8787
SNIPER_LOCAL_DASHBOARD_URL=http://127.0.0.1:8787/dashboard
